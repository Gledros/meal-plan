{
	"extends": "astro/tsconfigs/strict",
	"include": [
		".astro/types.d.ts",
		"**/*"
	],
	"exclude": [
		"dist"
	],
	"compilerOptions": {
		"paths": {
			"@components/*": [
				"./src/components/*"
			],
			"@layouts/*": [
				"./src/layouts/*"
			],
			"@data/*": [
				"./src/data/*"
			],
			"@assets/*": [
				"./public/images/*"
			],
			"@util": [
				"./src/util.ts"
			],
		},
	},
}