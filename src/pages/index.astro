---
import Layout from '@layouts/Layout.astro';
import { Image } from 'astro:assets';
import SmoothieCard from '@components/SmoothieCard.astro';
import RecipeCard from '@components/RecipeCard.astro';
import TabsSlider from '@components/TabsSlider.astro';
import Search from '@components/Search.astro';
import IngredientInfoModal from '@components/IngredientInfoModal.astro';
import GroceriesModal from '@components/GroceriesModal.astro';
import PortionMultiplier from '@components/PortionMultiplier.astro';
import w1_ShoppingList from '@data/weeks/w1_ShoppingList.json';
import w2_ShoppingList from '@data/weeks/w2_ShoppingList.json';
import w3_ShoppingList from '@data/weeks/w3_ShoppingList.json';
import w4_ShoppingList from '@data/weeks/w4_ShoppingList.json';
import {
	loadRecipesFromDisk,
	type MealDinnerRecipe,
	type SmoothieRecipe,
} from '@data/runtime-recipes';
import veganBadge from '../vegan-badge.svg';

type Smoothie = SmoothieRecipe;
type Breakfast = MealDinnerRecipe;
type Meal = MealDinnerRecipe;
type Dinner = MealDinnerRecipe;

const { smoothies, breakfasts, meals, dinners } = await loadRecipesFromDisk();

const tabs = [
	{ id: 'smoothies', label: 'Smoothies' },
	{ id: 'desayunos', label: 'Desayunos' },
	{ id: 'comidas', label: 'Comidas' },
	{ id: 'cenas', label: 'Cenas' },
];

const shoppingWeeks = [
	{ id: 'semana-1', label: 'Semana 1', week: w1_ShoppingList },
	{ id: 'semana-2', label: 'Semana 2', week: w2_ShoppingList },
	{ id: 'semana-3', label: 'Semana 3', week: w3_ShoppingList },
	{ id: 'semana-4', label: 'Semana 4', week: w4_ShoppingList },
];
---

<Layout title='Plan alimenticio'>
	<div
		class='print-header sticky top-0 z-10 border-b-2 border-[#b8b8b9] bg-white/80 p-4 backdrop-blur-sm'
		data-tabs-sticky-header
	>
		<div class='relative grid grid-cols-1 items-center gap-2 sm:min-h-24'>
			<div
				class='hidden sm:flex sm:absolute sm:left-0 sm:top-1/2 sm:-translate-y-1/2 sm:items-center'
			>
				<Image
					src={veganBadge}
					alt='Sello vegano'
					class='h-20 w-auto object-contain'
					loading='eager'
					decoding='async'
				/>
			</div>

			<div class='mx-auto w-full px-2 text-center sm:px-32 lg:px-40'>
				<h1 class='text-3xl font-bold sm:text-5xl'>Plan alimenticio</h1>
				<p class='mt-1 text-center text-xl font-semibold text-gray-600'>
					vegano, sin gluten, sin azúcar refinada, sin aceites añadidos
				</p>
			</div>

			<div
				class='mt-2 flex md:flex-col items-center gap-2 sm:absolute sm:inset-y-0 sm:right-0 sm:mt-0 justify-center'
			>
				<IngredientInfoModal
					title='Ingredientes por dificultad'
					triggerLabel='Ingredientes'
				/>
				<button
					type='button'
					class='inline-flex items-center justify-center gap-1 rounded-full border border-[#b8b8b9] bg-white/90 px-4 py-2 text-sm font-bold leading-none text-slate-700 transition hover:bg-slate-50 hover:cursor-pointer'
					onclick='window.print()'
					aria-label='Imprimir recetas del tab actual'
				>
					Imprimir
				</button>
			</div>
		</div>
	</div>
	<TabsSlider {tabs}>
		<div
			slot='tabs-controls-extra'
			class='tabs-controls-extra w-full lg:w-auto'
		>
			<div class='flex w-full flex-wrap items-center justify-center gap-3'>
				<Search placeholder='Busqueda' />
				<PortionMultiplier
					id='multiplier-select'
					wrapperClass='w-fit flex gap-2 items-center'
					labelClass='tabs-controls-label'
					selectClass='tabs-multiplier'
					ariaLabel='Multiplicar porciones'
					value={3}
				/>
				<GroceriesModal
					weeks={shoppingWeeks}
					title='Lista de compras'
					triggerLabel='Lista de compras'
				/>
			</div>
		</div>
		<section
			data-tab-panel='smoothies'
			class='tab-panel tab-panel--smoothies p-1 md:p-4'
		>
			<div
				class='print-smoothies-grid grid w-full grid-cols-1 gap-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 xl:grid-cols-6'
			>
				{
					smoothies.map(
						({ id, smoothie }: { id: number; smoothie: Smoothie }) => (
							<SmoothieCard {smoothie} {id} />
						),
					)
				}
			</div>
		</section>

		<section
			data-tab-panel='desayunos'
			class='tab-panel tab-panel--desayunos p-2 md:p-4'
		>
			{
				breakfasts.length > 0 ? (
					<div class='print-recipes-grid grid w-full grid-cols-1 gap-3 lg:grid-cols-2'>
						{breakfasts.map(
							({ id, breakfast }: { id: number; breakfast: Breakfast }) => (
								<RecipeCard
									id={id}
									recipe={breakfast}
									kind='Desayuno'
									color='#FFBD66'
								/>
							),
						)}
					</div>
				) : (
					<p class='rounded-xl border border-dashed border-gray-300 bg-gray-50 p-6 text-center text-lg text-gray-600'>
						No hay desayunos cargados todavía.
					</p>
				)
			}
		</section>

		<section
			data-tab-panel='comidas'
			class='tab-panel tab-panel--comidas p-2 md:p-4'
		>
			{
				meals.length > 0 ? (
					<div class='print-recipes-grid grid w-full grid-cols-1 gap-3 lg:grid-cols-2'>
						{meals.map(({ id, meal }: { id: number; meal: Meal }) => (
							<RecipeCard id={id} recipe={meal} kind='Comida' color='#9BCC7A' />
						))}
					</div>
				) : (
					<p class='rounded-xl border border-dashed border-gray-300 bg-gray-50 p-6 text-center text-lg text-gray-600'>
						No hay comidas cargadas todavía.
					</p>
				)
			}
		</section>

		<section
			data-tab-panel='cenas'
			class='tab-panel tab-panel--cenas p-2 md:p-4'
		>
			{
				dinners.length > 0 ? (
					<div class='print-recipes-grid grid w-full grid-cols-1 gap-3 lg:grid-cols-2'>
						{dinners.map(({ id, dinner }: { id: number; dinner: Dinner }) => (
							<RecipeCard id={id} recipe={dinner} kind='Cena' color='#A1B3FF' />
						))}
					</div>
				) : (
					<p class='mb-4 rounded-xl border border-dashed border-gray-300 bg-gray-50 p-6 text-center text-lg text-gray-600'>
						No hay cenas cargadas todavía.
					</p>
				)
			}
		</section>
	</TabsSlider>
</Layout>
