---
import Layout from '@layouts/Layout.astro';
import { Image } from 'astro:assets';
import SmoothieCard from '@components/SmoothieCard.astro';
import RecipeCard from '@components/RecipeCard.astro';
import TabsSlider from '@components/TabsSlider.astro';
import Search from '@components/Search.astro';
import IngredientInfoModal from '@components/IngredientInfoModal.astro';
import GroceriesModal from '@components/GroceriesModal.astro';
import PortionMultiplier from '@components/PortionMultiplier.astro';
import { WeekPrepSchema } from '@data/schemas/week-preparation';
import w1_ShoppingList from '@data/weeks/w1_ShoppingList.json';
import w2_ShoppingList from '@data/weeks/w2_ShoppingList.json';
import w3_ShoppingList from '@data/weeks/w3_ShoppingList.json';
import w4_ShoppingList from '@data/weeks/w4_ShoppingList.json';
import w1_PreparationRaw from '@data/weeks/w1_Preparation.json';
import w2_PreparationRaw from '@data/weeks/w2_Preparation.json';
import w3_PreparationRaw from '@data/weeks/w3_Preparation.json';
import w4_PreparationRaw from '@data/weeks/w4_Preparation.json';
import {
	type ExtraRecipe,
	loadRecipesFromDisk,
	type GuideRecipe,
	type MealDinnerRecipe,
	type SmoothieRecipe,
} from '@data/schemas/runtime-recipes';
import veganBadge from '../vegan-badge.svg';

type Smoothie = SmoothieRecipe;
type Breakfast = MealDinnerRecipe;
type Meal = MealDinnerRecipe;
type Dinner = MealDinnerRecipe;
type Extra = ExtraRecipe;
type Guide = GuideRecipe;

const { smoothies, breakfasts, meals, dinners, extras, guides } =
	await loadRecipesFromDisk();

const tabs = [
	{ id: 'smoothies', label: 'Smoothies' },
	{ id: 'desayunos', label: 'Desayunos' },
	{ id: 'comidas', label: 'Comidas' },
	{ id: 'cenas', label: 'Cenas' },
	{ id: 'extras', label: 'Extras' },
	{ id: 'guias', label: 'Guías' },
];

const shoppingWeeks = [
	{ id: 'semana-1', label: 'Semana 1', week: w1_ShoppingList },
	{ id: 'semana-2', label: 'Semana 2', week: w2_ShoppingList },
	{ id: 'semana-3', label: 'Semana 3', week: w3_ShoppingList },
	{ id: 'semana-4', label: 'Semana 4', week: w4_ShoppingList },
];

const preparationWeeks = [
	{
		id: 'semana-1',
		label: 'Semana 1',
		week: WeekPrepSchema.parse(w1_PreparationRaw),
	},
	{
		id: 'semana-2',
		label: 'Semana 2',
		week: WeekPrepSchema.parse(w2_PreparationRaw),
	},
	{
		id: 'semana-3',
		label: 'Semana 3',
		week: WeekPrepSchema.parse(w3_PreparationRaw),
	},
	{
		id: 'semana-4',
		label: 'Semana 4',
		week: WeekPrepSchema.parse(w4_PreparationRaw),
	},
];
---

<Layout title='Plan alimenticio'>
	<div
		class='print-header sticky top-0 z-10 border-b-2 p-4'
		data-tabs-sticky-header
	>
		<div class='relative grid grid-cols-1 items-center gap-2 sm:min-h-24'>
			<div
				class='hidden sm:flex sm:absolute sm:left-0 sm:top-1/2 sm:-translate-y-1/2 sm:items-center'
			>
				<Image
					src={veganBadge}
					alt='Sello vegano'
					class='h-20 w-auto object-contain'
					loading='eager'
					decoding='async'
				/>
			</div>

			<div class='mx-auto w-full px-2 text-center sm:px-32 lg:px-40'>
				<h1 class='text-3xl font-bold sm:text-5xl'>Plan alimenticio</h1>
				<p class='mt-1 text-center text-xl font-semibold text-gray-600'>
					vegano, sin gluten, sin azúcar refinada, sin aceites añadidos
				</p>
			</div>

			<div
				class='mt-2 flex md:flex-col items-center gap-2 sm:absolute sm:inset-y-0 sm:right-0 sm:mt-0 justify-center'
			>
				<IngredientInfoModal
					title='Ingredientes por dificultad'
					triggerLabel='Ingredientes'
				/>
				<button
					type='button'
					class='inline-flex items-center justify-center gap-1 rounded-full border border-[#b8b8b9] bg-white/90 px-4 py-2 text-sm font-bold leading-none text-slate-700 transition hover:bg-slate-50 hover:cursor-pointer'
					onclick='window.print()'
					aria-label='Imprimir recetas del tab actual'
				>
					Imprimir
				</button>
			</div>
		</div>
	</div>
	<TabsSlider {tabs}>
		<div
			slot='tabs-controls-extra'
			class='tabs-controls-extra w-full lg:w-auto'
		>
			<div class='flex w-full flex-wrap items-center justify-center gap-3'>
				<Search placeholder='Busqueda' />
				<PortionMultiplier
					id='multiplier-select'
					wrapperClass='w-fit flex gap-2 items-center'
					labelClass='tabs-controls-label'
					selectClass='tabs-multiplier'
					ariaLabel='Multiplicar porciones'
					value={3}
				/>
				<GroceriesModal
					weeks={shoppingWeeks}
					preparationWeeks={preparationWeeks}
					title='Lista de compras'
					triggerLabel='Lista de compras'
				/>
			</div>
		</div>
		<section
			data-tab-panel='smoothies'
			class='tab-panel tab-panel--smoothies p-1 md:p-4'
		>
			<div
				class='print-smoothies-grid grid w-full grid-cols-1 gap-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 xl:grid-cols-6'
			>
				{
					smoothies.map(
						({ id, smoothie }: { id: number; smoothie: Smoothie }) => (
							<SmoothieCard {smoothie} {id} />
						),
					)
				}
			</div>
		</section>

		<section
			data-tab-panel='desayunos'
			class='tab-panel tab-panel--desayunos p-2 md:p-4'
		>
			{
				breakfasts.length > 0 ? (
					<div class='print-recipes-grid grid w-full grid-cols-1 gap-3 lg:grid-cols-2'>
						{breakfasts.map(
							({ id, breakfast }: { id: number; breakfast: Breakfast }) => (
								<RecipeCard
									id={id}
									recipe={breakfast}
									kind='Desayuno'
									color='#FFBD66'
								/>
							),
						)}
					</div>
				) : (
					<p class='rounded-xl border border-dashed border-gray-300 bg-gray-50 p-6 text-center text-lg text-gray-600'>
						No hay desayunos cargados todavía.
					</p>
				)
			}
		</section>

		<section
			data-tab-panel='comidas'
			class='tab-panel tab-panel--comidas p-2 md:p-4'
		>
			{
				meals.length > 0 ? (
					<div class='print-recipes-grid grid w-full grid-cols-1 gap-3 lg:grid-cols-2'>
						{meals.map(({ id, meal }: { id: number; meal: Meal }) => (
							<RecipeCard id={id} recipe={meal} kind='Comida' color='#9BCC7A' />
						))}
					</div>
				) : (
					<p class='rounded-xl border border-dashed border-gray-300 bg-gray-50 p-6 text-center text-lg text-gray-600'>
						No hay comidas cargadas todavía.
					</p>
				)
			}
		</section>

		<section
			data-tab-panel='cenas'
			class='tab-panel tab-panel--cenas p-2 md:p-4'
		>
			{
				dinners.length > 0 ? (
					<div class='print-recipes-grid grid w-full grid-cols-1 gap-3 lg:grid-cols-2'>
						{dinners.map(({ id, dinner }: { id: number; dinner: Dinner }) => (
							<RecipeCard id={id} recipe={dinner} kind='Cena' color='#A1B3FF' />
						))}
					</div>
				) : (
					<p class='mb-4 rounded-xl border border-dashed border-gray-300 bg-gray-50 p-6 text-center text-lg text-gray-600'>
						No hay cenas cargadas todavía.
					</p>
				)
			}
		</section>

		<section
			data-tab-panel='extras'
			class='tab-panel tab-panel--extras p-2 md:p-4'
		>
			{
				extras.length > 0 ? (
					<div class='print-recipes-grid grid w-full grid-cols-1 gap-3 lg:grid-cols-2'>
						{extras.map(({ id, extra }) => (
							<RecipeCard id={id} recipe={extra} kind='Extra' color='#E6B86E' />
						))}
					</div>
				) : (
					<p class='mb-4 rounded-xl border border-dashed border-gray-300 bg-gray-50 p-6 text-center text-lg text-gray-600'>
						No hay extras cargados todavía.
					</p>
				)
			}
		</section>

		<section
			data-tab-panel='guias'
			class='tab-panel tab-panel--guias p-2 md:p-4'
		>
			{
				guides.length > 0 ? (
					<div class='print-recipes-grid grid w-full grid-cols-1 gap-3 lg:grid-cols-2'>
						{guides.map(({ id, guide }: { id: number; guide: Guide }) => (
							<RecipeCard id={id} recipe={guide} kind='Guía' color='#8CB7A4' />
						))}
					</div>
				) : (
					<p class='mb-4 rounded-xl border border-dashed border-gray-300 bg-gray-50 p-6 text-center text-lg text-gray-600'>
						No hay guías cargadas todavía.
					</p>
				)
			}
		</section>
	</TabsSlider>
</Layout>

<script is:inline>
	(() => {
		const HEADER_SELECTOR = '[data-tabs-sticky-header]';
		const PANEL_SELECTOR = '[data-tabs-track] > [data-tab-panel]';
		const desktopQuery = window.matchMedia('(min-width: 1024px)');
		const header = document.querySelector(HEADER_SELECTOR);

		if (!(header instanceof HTMLElement)) {
			return;
		}

		const rootElement = document.documentElement;
		let isHeaderHidden = false;
		const panelScrollState = new WeakMap();

		const updateHeaderLayoutVars = () => {
			const headerHeight = header.getBoundingClientRect().height;
			header.style.setProperty('--sticky-header-height', `${headerHeight}px`);

			const headerSpace =
				desktopQuery.matches && isHeaderHidden ? 0 : headerHeight;
			rootElement.style.setProperty(
				'--sticky-header-space',
				`${Math.max(0, headerSpace)}px`,
			);
		};

		const setHeaderHidden = (nextHidden) => {
			if (isHeaderHidden === nextHidden) {
				return;
			}

			isHeaderHidden = nextHidden;
			header.classList.toggle('is-scroll-hidden', nextHidden);
			updateHeaderLayoutVars();
		};

		const handlePanelScroll = (event) => {
			const panel = event.currentTarget;
			if (!(panel instanceof HTMLElement)) {
				return;
			}

			if (panel.getAttribute('aria-hidden') === 'true') {
				return;
			}

			const currentScrollTop = panel.scrollTop;
			const previousScrollTop = panelScrollState.has(panel)
				? panelScrollState.get(panel)
				: currentScrollTop;
			panelScrollState.set(panel, currentScrollTop);

			if (!desktopQuery.matches) {
				setHeaderHidden(false);
				return;
			}

			const delta = currentScrollTop - previousScrollTop;
			const reachedTopFromScrollUp =
				currentScrollTop <= 8 && previousScrollTop > 8 && delta < 0;

			if (delta < -8 || reachedTopFromScrollUp) {
				setHeaderHidden(false);
			} else if (delta > 8) {
				setHeaderHidden(true);
			}
		};

		const bindPanelScrollListeners = () => {
			const panels = document.querySelectorAll(PANEL_SELECTOR);
			for (const panel of panels) {
				if (!(panel instanceof HTMLElement)) {
					continue;
				}

				if (panel.hasAttribute('data-header-scroll-bound')) {
					continue;
				}

				panel.setAttribute('data-header-scroll-bound', 'true');
				panelScrollState.set(panel, panel.scrollTop);
				panel.addEventListener('scroll', handlePanelScroll, {
					passive: true,
				});
			}
		};

		const syncHeaderState = () => {
			updateHeaderLayoutVars();
			bindPanelScrollListeners();

			if (!desktopQuery.matches) {
				setHeaderHidden(false);
			}
		};

		window.addEventListener('resize', syncHeaderState, {
			passive: true,
		});

		desktopQuery.addEventListener('change', syncHeaderState);

		if ('ResizeObserver' in window) {
			const headerObserver = new ResizeObserver(() => {
				updateHeaderLayoutVars();
			});
			headerObserver.observe(header);
		}

		syncHeaderState();
	})();
</script>

<style>
	[data-tabs-sticky-header] {
		--sticky-header-height: 0px;
		transition:
			transform 220ms ease,
			margin-bottom 220ms ease;
		will-change: transform;
	}

	@media (min-width: 1024px) {
		[data-tabs-sticky-header].is-scroll-hidden {
			transform: translateY(calc(-100% - 0.5rem));
			pointer-events: none;
			margin-bottom: calc(-1 * var(--sticky-header-height));
		}
	}
</style>
