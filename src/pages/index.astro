---
import Layout from '@layouts/Layout.astro';
import { Image } from 'astro:assets';
import SmoothieCard from '@components/SmoothieCard.astro';
import RecipeCard from '@components/RecipeCard.astro';
import TabsSlider from '@components/TabsSlider.astro';
import ReadmeModal from '@components/ReadmeModal.astro';
import IngredientsModal from '@components/IngredientsModal.astro';
import PortionMultiplier from '@components/PortionMultiplier.astro';
import week1 from '@data/weeks/w1.json';
import week2 from '@data/weeks/w2.json';
import week3 from '@data/weeks/w3.json';
import week4 from '@data/weeks/w4.json';
import {
	loadRecipesFromDisk,
	type MealDinnerRecipe,
	type SmoothieRecipe,
} from '@data/runtime-recipes';
import ReadmeContent from '../../README.md';
import veganBadge from '../vegan-badge.svg';

type Smoothie = SmoothieRecipe;
type Breakfast = MealDinnerRecipe;
type Meal = MealDinnerRecipe;
type Dinner = MealDinnerRecipe;

const { smoothies, breakfasts, meals, dinners } = await loadRecipesFromDisk();

const tabs = [
	{ id: 'smoothies', label: 'Smoothies' },
	{ id: 'desayunos', label: 'Desayunos' },
	{ id: 'comidas', label: 'Comidas' },
	{ id: 'cenas', label: 'Cenas' },
];

const shoppingWeeks = [
	{ id: 'semana-1', label: 'Semana 1', week: week1 },
	{ id: 'semana-2', label: 'Semana 2', week: week2 },
	{ id: 'semana-3', label: 'Semana 3', week: week3 },
	{ id: 'semana-4', label: 'Semana 4', week: week4 },
];
---

<Layout title='Plan alimenticio'>
	<div
		class='print-header sticky top-0 z-10 border-b-2 border-[#b8b8b9] bg-white/80 p-4 backdrop-blur-sm'
		data-tabs-sticky-header
	>
		<div class='grid grid-cols-1 items-center gap-3 sm:grid-cols-[auto_1fr]'>
			<Image
				src={veganBadge}
				alt='Sello vegano'
				class='hidden h-16 w-auto object-contain sm:block sm:h-20'
				loading='eager'
				decoding='async'
			/>
			<div
				class='grid grid-cols-1 items-center gap-x-3 gap-y-1 sm:grid-cols-[1fr_auto]'
			>
				<h1
					class='order-1 self-center text-center text-3xl font-bold sm:text-5xl'
				>
					Plan alimenticio
				</h1>
				<div
					class='order-3 mt-1 self-center justify-self-center sm:order-2 sm:col-start-2 sm:row-start-1 sm:mt-0 sm:justify-self-end'
				>
					<ReadmeModal title='Ayuda'>
						<ReadmeContent />
					</ReadmeModal>
				</div>
				<p
					class='order-2 text-center text-xl font-semibold text-gray-600 sm:order-3 sm:col-span-2'
				>
					vegano, sin gluten, sin azúcar refinada, sin aceites añadidos
				</p>
			</div>
		</div>
	</div>
	<TabsSlider {tabs}>
		<div slot='tabs-controls-extra' class='tabs-controls-extra'>
			<div class='flex items-center gap-4'>
				<PortionMultiplier
					id='multiplier-select'
					wrapperClass='w-fit flex gap-2 items-center'
					labelClass='tabs-controls-label'
					selectClass='tabs-multiplier'
					ariaLabel='Multiplicar porciones'
					value={3}
				/>
				<IngredientsModal
					weeks={shoppingWeeks}
					title='Lista de compras'
					triggerLabel='Lista de compras'
				/>
			</div>
		</div>
		<section data-tab-panel='smoothies' class='p-1 md:p-4'>
			<div
				class='print-grid grid w-full grid-cols-1 gap-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 xl:grid-cols-6'
			>
				{
					smoothies.map(
						({ id, smoothie }: { id: number; smoothie: Smoothie }) => (
							<SmoothieCard {smoothie} {id} />
						),
					)
				}
			</div>
		</section>

		<section data-tab-panel='desayunos' class='p-2 md:p-4'>
			{
				breakfasts.length > 0 ? (
					<div class='grid w-full grid-cols-1 gap-3 lg:grid-cols-2'>
						{breakfasts.map(
							({ id, breakfast }: { id: number; breakfast: Breakfast }) => (
								<RecipeCard
									id={id}
									recipe={breakfast}
									kind='Desayuno'
									color='#FFBD66'
								/>
							),
						)}
					</div>
				) : (
					<p class='rounded-xl border border-dashed border-gray-300 bg-gray-50 p-6 text-center text-lg text-gray-600'>
						No hay desayunos cargados todavía.
					</p>
				)
			}
		</section>

		<section data-tab-panel='comidas' class='p-2 md:p-4'>
			{
				meals.length > 0 ? (
					<div class='grid w-full grid-cols-1 gap-3 lg:grid-cols-2'>
						{meals.map(({ id, meal }: { id: number; meal: Meal }) => (
							<RecipeCard id={id} recipe={meal} kind='Comida' color='#9BCC7A' />
						))}
					</div>
				) : (
					<p class='rounded-xl border border-dashed border-gray-300 bg-gray-50 p-6 text-center text-lg text-gray-600'>
						No hay comidas cargadas todavía.
					</p>
				)
			}
		</section>

		<section data-tab-panel='cenas' class='p-2 md:p-4'>
			{
				dinners.length > 0 ? (
					<div class='grid w-full grid-cols-1 gap-3 lg:grid-cols-2'>
						{dinners.map(({ id, dinner }: { id: number; dinner: Dinner }) => (
							<RecipeCard id={id} recipe={dinner} kind='Cena' color='#A1B3FF' />
						))}
					</div>
				) : (
					<p class='mb-4 rounded-xl border border-dashed border-gray-300 bg-gray-50 p-6 text-center text-lg text-gray-600'>
						No hay cenas cargadas todavía.
					</p>
				)
			}
		</section>
	</TabsSlider>
</Layout>
