---
import Layout from "@layouts/Layout.astro";
import SmoothieCard from "@components/SmoothieCard.astro";
import TabsSlider from "@components/TabsSlider.astro";
import { getCollection, type InferEntrySchema } from "astro:content";

type Smoothie = InferEntrySchema<"Smoothies">;
type Meal = InferEntrySchema<"Meals">;
type Dinner = InferEntrySchema<"Dinners">;

const parseNumericId = (value: string) => {
	const match = value.match(/\d+/);
	return match ? Number.parseInt(match[0], 10) : Number.MAX_SAFE_INTEGER;
};

const smoothieEntries = await getCollection("Smoothies");
const mealEntries = await getCollection("Meals");
const dinnerEntries = await getCollection("Dinners");

const smoothies = smoothieEntries
	.map((entry) => ({
		id: parseNumericId(entry.id),
		smoothie: entry.data,
	}))
	.sort((a, b) => a.id - b.id);

const meals = mealEntries
	.map((entry) => ({
		id: parseNumericId(entry.id),
		meal: entry.data,
	}))
	.sort((a, b) => a.id - b.id);

const dinners = dinnerEntries
	.map((entry) => ({
		id: parseNumericId(entry.id),
		dinner: entry.data,
	}))
	.sort((a, b) => a.id - b.id);

const tabs = [
	{ id: "smoothies", label: "Smoothies" },
	{ id: "comidas", label: "Comidas" },
	{ id: "cenas", label: "Cenas" },
];
---

<Layout title="Meal Plan">
	<div
		class='print-header sticky top-0 z-10 border-b-2 border-[#b8b8b9] bg-white/80 p-4 backdrop-blur-sm'
		data-tabs-sticky-header
	>
		<h1 class='text-center text-5xl font-bold'>Meal Plan</h1>
		<!-- <p class='text-center text-xl font-semibold text-gray-600'>
			smoothies, comidas y cenas
		</p> -->
	</div>
	<TabsSlider {tabs}>
		<section data-tab-panel='smoothies' class='p-1 md:p-4'>
			<div class='print-grid grid w-full grid-cols-1 gap-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 xl:grid-cols-6'>
				{
					smoothies.map(({ id, smoothie }: { id: number; smoothie: Smoothie }) => (
						<SmoothieCard {smoothie} {id} />
					))
				}
			</div>
		</section>

		<section data-tab-panel='comidas' class='p-2 md:p-4'>
			<div class='grid w-full grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-3'>
				{
					meals.map(({ id, meal }: { id: number; meal: Meal }) => (
						<article class='rounded-xl border-2 border-emerald-200 bg-emerald-50/60 p-4 shadow-sm'>
							<div class='mb-3 flex items-baseline justify-between gap-2'>
								<h2 class='text-xl font-bold text-emerald-900'>
									{`Comida ${id}`}
								</h2>
								<span class='rounded-full bg-emerald-100 px-2 py-1 text-sm font-semibold text-emerald-800'>
									{meal.informacion_nutricional.kcal} kcal
								</span>
							</div>
							<h3 class='text-lg font-semibold leading-tight text-emerald-950'>
								{meal.nombre}
							</h3>
							<p class='mt-3 text-sm font-semibold uppercase tracking-wide text-emerald-800'>
								Ingredientes (1 porcion)
							</p>
							<ul class='mt-1 space-y-1'>
								{
									meal.ingredientes.map((ingredient) => (
										<li class="list-none list-outside relative pl-5 text-base text-emerald-950 before:absolute before:left-0 before:content-['-']">
											{ingredient}
										</li>
									))
								}
							</ul>
							<p class='mt-3 text-sm font-semibold uppercase tracking-wide text-emerald-800'>
								Pasos
							</p>
							<ol class='mt-1 space-y-1'>
								{
									meal.pasos.map((step) => (
										<li class='list-decimal list-inside text-base text-emerald-950'>
											{step}
										</li>
									))
								}
							</ol>
						</article>
					))
				}
			</div>
		</section>

		<section data-tab-panel='cenas' class='p-2 md:p-4'>
			<div class='grid w-full grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-3'>
				{
					dinners.map(({ id, dinner }: { id: number; dinner: Dinner }) => (
						<article class='rounded-xl border-2 border-orange-200 bg-orange-50/60 p-4 shadow-sm'>
							<div class='mb-3 flex items-baseline justify-between gap-2'>
								<h2 class='text-xl font-bold text-orange-900'>
									{`Cena ${id}`}
								</h2>
								<span class='rounded-full bg-orange-100 px-2 py-1 text-sm font-semibold text-orange-800'>
									{dinner.informacion_nutricional.kcal} kcal
								</span>
							</div>
							<h3 class='text-lg font-semibold leading-tight text-orange-950'>
								{dinner.nombre}
							</h3>
							<p class='mt-3 text-sm font-semibold uppercase tracking-wide text-orange-800'>
								Ingredientes (1 porcion)
							</p>
							<ul class='mt-1 space-y-1'>
								{
									dinner.ingredientes.map((ingredient) => (
										<li class="list-none list-outside relative pl-5 text-base text-orange-950 before:absolute before:left-0 before:content-['-']">
											{ingredient}
										</li>
									))
								}
							</ul>
							<p class='mt-3 text-sm font-semibold uppercase tracking-wide text-orange-800'>
								Pasos
							</p>
							<ol class='mt-1 space-y-1'>
								{
									dinner.pasos.map((step) => (
										<li class='list-decimal list-inside text-base text-orange-950'>
											{step}
										</li>
									))
								}
							</ol>
						</article>
					))
				}
			</div>
		</section>
	</TabsSlider>
</Layout>
