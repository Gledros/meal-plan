---
interface Props {
	id: string;
	label?: string;
	options?: number[];
	value?: number;
	ariaLabel?: string;
	wrapperClass?: string;
	labelClass?: string;
	selectClass?: string;
}

const {
	id,
	label = 'Porciones',
	options = [1, 3, 5],
	value = 3,
	ariaLabel = 'Multiplicar porciones',
	wrapperClass = '',
	labelClass = '',
	selectClass = '',
} = Astro.props;

const normalizedOptions =
	Array.isArray(options) && options.length > 0 ? options : [1, 3, 5];
const normalizedValue = normalizedOptions.includes(value)
	? value
	: normalizedOptions[0];
---

<div class={wrapperClass}>
	<label class={labelClass} for={id}>{label}</label>
	<select
		id={id}
		class={selectClass}
		data-portion-multiplier
		aria-label={ariaLabel}
	>
		{
			normalizedOptions.map((option) => (
				<option value={option} selected={option === normalizedValue}>
					x{option}
				</option>
			))
		}
	</select>
</div>

<script is:inline>
	(() => {
		const STORE_KEY = '__portionMultiplierSyncStore';
		const SELECTOR = '[data-portion-multiplier]';
		const EVENT_NAME = 'portions-multiplier:change';

		const parseMultiplier = (value) => {
			const parsed = Number(value);
			return Number.isFinite(parsed) && parsed > 0 ? parsed : 1;
		};

		const getSelects = () =>
			Array.from(document.querySelectorAll(SELECTOR)).filter(
				(node) => node instanceof HTMLSelectElement,
			);

		if (typeof window === 'undefined') {
			return;
		}

		if (!window[STORE_KEY]) {
			window[STORE_KEY] = {
				currentMultiplier: 1,
				initialized: false,
				isBound: false,
			};
		}

		const store = window[STORE_KEY];

		const syncSelects = (sourceSelect = null) => {
			const currentValue = String(store.currentMultiplier);
			getSelects().forEach((select) => {
				if (select !== sourceSelect) {
					select.value = currentValue;
				}
			});
		};

		const emitMultiplierChange = () => {
			window.dispatchEvent(
				new CustomEvent(EVENT_NAME, {
					detail: { multiplier: store.currentMultiplier },
				}),
			);
		};

		const setMultiplier = (nextValue, sourceSelect = null, emit = true) => {
			const next = parseMultiplier(nextValue);
			store.currentMultiplier = next;
			syncSelects(sourceSelect);
			if (emit) {
				emitMultiplierChange();
			}
		};

		if (!store.isBound) {
			document.addEventListener('change', (event) => {
				const target = event.target;
				if (
					!(target instanceof HTMLSelectElement) ||
					!target.matches(SELECTOR)
				) {
					return;
				}
				setMultiplier(target.value, target, true);
			});
			store.isBound = true;
		}

		const selects = getSelects();
		if (selects.length === 0) {
			return;
		}

		if (!store.initialized) {
			setMultiplier(selects[0].value, null, true);
			store.initialized = true;
			return;
		}

		syncSelects();
	})();
</script>
