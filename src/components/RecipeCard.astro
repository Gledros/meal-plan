---
import { type MealDinnerRecipe } from '@data/runtime-recipes';
import { Icon } from 'astro-icon/components';
import { lightenHexColor, darkenHexColor, formatQuantity } from '@util';

interface Props {
	id: number;
	recipe: MealDinnerRecipe;
	kind: 'Desayuno' | 'Comida' | 'Cena';
	color: string;
}

const { id, recipe, kind, color } = Astro.props;
const displayId = recipe.id ?? id;
const unitTranslations = {
	minutes: 'minutos',
	hours: 'horas',
	days: 'días',
};

const formatTime = (t: { tiempo: number; unidad: string }) =>
	`${t.tiempo} ${unitTranslations[t.unidad as keyof typeof unitTranslations] ?? t.unidad}`;
const prepTimeNotes = recipe.tiempo_preparacion.notas.trim();
const cookTimeNotes = recipe.tiempo_cocinado.notas.trim();
const recipeNotes = recipe.notas.filter((note) => note.trim().length > 0);
const borderHex = darkenHexColor(color, 0.2);
const nutritionHex = lightenHexColor(color, 0.5);
const cardBorderStyle = `border-color: ${borderHex} !important; forced-color-adjust: none;`;
const headerBgStyle = `background-color: ${color} !important; forced-color-adjust: none;`;
const headerTextStyle = 'color: #000000 !important; forced-color-adjust: none;';
const timeBorderStyle = `border-color: ${borderHex} !important; forced-color-adjust: none;`;
const nutritionBgStyle = `background-color: ${nutritionHex} !important; color: #000000 !important; forced-color-adjust: none;`;
---

<div
	id={`recipe-${recipe.referencia}`}
	class='meal-dinner-card border-3 rounded-xl overflow-hidden flex flex-col'
	style={cardBorderStyle}
>
	<div class='p-2' style={headerBgStyle}>
		<h2 class='text-xl font-bold text-center' style={headerTextStyle}>
			{`${kind} ${displayId}`}<br />{recipe.nombre}
		</h2>
	</div>
	<div class='p-2 flex-1 flex flex-col'>
		<div class='mb-2 grid grid-cols-2 gap-2'>
			<div class='rounded-lg border-2 p-2 text-center' style={timeBorderStyle}>
				<p class='text-sm font-semibold tracking-wide'>preparación</p>
				<p class='text-lg font-bold leading-tight'>
					{formatTime(recipe.tiempo_preparacion)}
				</p>
				{prepTimeNotes && <p class='text-sm leading-tight'>{prepTimeNotes}</p>}
			</div>
			<div class='rounded-lg border-2 p-2 text-center' style={timeBorderStyle}>
				<p class='text-sm font-semibold tracking-wide'>cocinado</p>
				<p class='text-lg font-bold leading-tight'>
					{formatTime(recipe.tiempo_cocinado)}
				</p>
				{cookTimeNotes && <p class='text-sm leading-tight'>{cookTimeNotes}</p>}
			</div>
		</div>

		<div class='grid items-start gap-2 md:grid-cols-2'>
			<div>
				<p
					class='mb-1 text-lg text-center font-semibold'
					data-ingredients-header
				>
					Ingredientes (1 porción)
				</p>
				<ul class='p-2 space-y-1'>
					{
						recipe.ingredientes.map((ing) => (
							<li class='flex items-baseline gap-2 text-base'>
								<span class='shrink-0 text-lg leading-none'>✅</span>
								<span>
									<span
										class='font-semibold ingredient-quantity'
										data-qty-base={ing.cantidad}
										data-qty-unit={ing.unidad_display}
									>
										<span class='ingredient-qty-value'>
											{formatQuantity(ing.cantidad, ing.unidad_display)}
										</span>
										<span class='ingredient-qty-unit'>
											{' '}
											{ing.unidad_display}
										</span>
									</span>{' '}
									<span class='ingredient-name'>{ing.nombre}</span>
									{ing.estado && (
										<span class='text-sm text-gray-500 italic'>
											{' '}
											— {ing.estado}
										</span>
									)}
								</span>
							</li>
						))
					}
				</ul>
			</div>
			<div
				class='perfil-nutricional m-1 p-1 rounded-xl'
				style={nutritionBgStyle}
			>
				<h3 class='text-center font-bold text-xl'>Perfil nutricional</h3>
				<div class='w-full grid grid-cols-2 gap-2 p-2'>
					<div class='flex flex-col items-center gap-1'>
						<Icon name='noto:fire' size={40} />
						<p class='text-lg'>
							Energía<br />{recipe.informacion_nutricional.kcal} kcal
						</p>
					</div>
					<div class='flex flex-col items-center gap-1'>
						<Icon name='noto:baguette-bread' size={40} />
						<p class='text-lg'>
							Carbohidrato<br />{recipe.informacion_nutricional.carbohidratos_g} g
						</p>
					</div>
					<div class='flex flex-col items-center gap-1'>
						<Icon name='noto:butter' size={40} />
						<p class='text-lg'>
							Grasa<br />{recipe.informacion_nutricional.grasas_g} g
						</p>
					</div>
					<div class='flex flex-col items-center gap-1'>
						<Icon name='noto:cut-of-meat' size={40} />
						<p class='text-lg'>
							Proteína<br />{recipe.informacion_nutricional.proteina_g} g
						</p>
					</div>
				</div>
			</div>
		</div>

		<p class='mb-1 mt-2 text-lg text-center font-semibold'>Pasos</p>
		<ol class='px-8 pb-2 list-decimal space-y-1'>
			{recipe.pasos.map((paso) => <li class='text-lg'>{paso}</li>)}
		</ol>

		{
			recipeNotes.length > 0 && (
				<details
					class='recipe-notes mt-auto rounded-lg border p-2'
					style={timeBorderStyle}
				>
					<summary class='text-lg font-semibold text-center'>Notas</summary>
					<ul class='px-8 pb-2 list-disc space-y-1 mt-2'>
						{recipeNotes.map((note) => (
							<li class='text-lg'>{note}</li>
						))}
					</ul>
				</details>
			)
		}
	</div>
</div>

<style>
	.perfil-nutricional p {
		text-align: center;
	}

	.recipe-notes summary {
		list-style: none;
		cursor: pointer;
	}

	.recipe-notes summary::-webkit-details-marker {
		display: none;
	}

	.recipe-notes summary::after {
		content: '▾';
		display: inline-block;
		margin-left: 0.5rem;
		transition: transform 120ms ease-in-out;
	}

	.recipe-notes[open] summary::after {
		transform: rotate(180deg);
	}
</style>
