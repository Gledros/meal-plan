---
import PortionMultiplier from './PortionMultiplier.astro';
import TabsSlider from './TabsSlider.astro';

type IngredientItem = {
	cantidad: number;
	unidad?: string;
	nombre: string;
	[key: string]: unknown;
};

type WeekCategory = {
	notas?: string;
	lista: IngredientItem[];
};

type WeekData = Record<string, unknown>;

interface WeekConfig {
	id?: string;
	label?: string;
	week: WeekData;
	title?: string;
}

interface PreparedWeekConfig {
	id: string;
	label: string;
	week: WeekData;
	sectionColumns: string[][];
	storageKey: string;
}

interface Props {
	week?: WeekData;
	weeks?: WeekConfig[];
	title?: string;
	triggerLabel?: string;
}

const {
	week,
	weeks = [],
	title = 'Lista de compras',
	triggerLabel = 'Lista de compras',
} = Astro.props;

const categoryNames: Record<string, string> = {
	frutas_verduras: 'Frutas y verduras',
	refrigerados_congelados: 'Refrigerados / Congelados',
	despensa: 'Despensa',
	basicos: 'Básicos',
};

const desktopColumnOrder = [
	['frutas_verduras'],
	['refrigerados_congelados', 'basicos'],
	['despensa'],
];

const isWeekCategory = (value: unknown): value is WeekCategory => {
	if (!value || typeof value !== 'object') return false;
	const category = value as WeekCategory;
	return Array.isArray(category.lista);
};

const getValidCategoryKeys = (weekData: WeekData) =>
	Object.keys(weekData).filter((key) => isWeekCategory(weekData[key]));

const getSectionColumns = (weekData: WeekData) => {
	const categoryKeys = getValidCategoryKeys(weekData);
	const knownCategoryKeys = new Set(desktopColumnOrder.flat());
	const remainingCategoryKeys = categoryKeys.filter(
		(key) => !knownCategoryKeys.has(key),
	);

	return desktopColumnOrder
		.map((columnKeys, index) =>
			(index === 2
				? [...columnKeys, ...remainingCategoryKeys]
				: columnKeys
			).filter((key) => categoryKeys.includes(key)),
		)
		.filter((columnKeys) => columnKeys.length > 0);
};

const normalizeIdentifierPart = (value: unknown) =>
	String(value ?? '')
		.normalize('NFD')
		.replace(/[\u0300-\u036f]/g, '')
		.toLowerCase()
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/(^-|-$)/g, '');

const getIngredientId = (
	weekId: string,
	categoryKey: string,
	item: Record<string, unknown>,
	index: number,
) =>
	[
		normalizeIdentifierPart(weekId),
		normalizeIdentifierPart(categoryKey),
		normalizeIdentifierPart(item.nombre),
		normalizeIdentifierPart(item.unidad) || 'sin-unidad',
		normalizeIdentifierPart(item.cantidad) || 'sin-cantidad',
		String(index),
	].join('__');

const hashString = (value: string) => {
	let hash = 0;
	for (let i = 0; i < value.length; i += 1) {
		hash = (hash * 31 + value.charCodeAt(i)) | 0;
	}
	return Math.abs(hash).toString(36);
};

const sourceWeeks: WeekConfig[] =
	weeks.length > 0
		? weeks
		: [{ id: 'semana-1', label: 'Semana 1', week: week ?? {} }];

const resolvedWeeks: PreparedWeekConfig[] = sourceWeeks.map((entry, index) => {
	const weekNumber = Number((entry.week as Record<string, unknown>).semana);
	const label =
		entry.label ??
		(Number.isFinite(weekNumber) && weekNumber > 0
			? `Semana ${weekNumber}`
			: `Semana ${index + 1}`);
	const id =
		normalizeIdentifierPart(entry.id ?? label) || `semana-${index + 1}`;
	const weekTitle = entry.title ?? `${title} (${label.toLowerCase()})`;
	return {
		id,
		label,
		week: entry.week,
		sectionColumns: getSectionColumns(entry.week),
		storageKey: `ingredients-checklist-${hashString(
			`${weekTitle}:${id}:${JSON.stringify(entry.week)}`,
		)}`,
	};
});

const modalBaseId = normalizeIdentifierPart(title) || 'lista-de-compras';
const defaultWeekId = resolvedWeeks[0]?.id ?? '';
const weekTabs = resolvedWeeks.map(({ id, label }) => ({ id, label }));

// Mapeo de unidades para display en español
const unitDisplayMap: Record<string, string> = {
	piece: 'pieza',
	unit: 'unidad',
	unidad: 'unidad',
	pieza: 'pieza',
	g: 'g',
	gr: 'g',
	gramos: 'g',
	kg: 'kg',
	ml: 'ml',
	l: 'l',
	taza: 'taza',
	cup: 'taza',
	cda: 'cda',
	cucharada: 'cda',
	tbsp: 'cda',
	cdita: 'cdita',
	cucharadita: 'cdita',
	tsp: 'cdita',
	scoop: 'scoop',
	slice: 'rebanada',
	rebanada: 'rebanada',
};

const displayUnit = (u: unknown) => {
	if (!u) return '';
	const key = String(u).trim().toLowerCase();
	return unitDisplayMap[key] ?? String(u);
};
---

<div
	class='ingredients-modal'
	data-ingredients-modal
	data-ingredients-default-week={defaultWeekId}
>
	<button
		type='button'
		class='ingredients-modal__trigger'
		data-ingredients-trigger
		aria-haspopup='dialog'
	>
		{triggerLabel}
	</button>

	<div
		class='ingredients-modal__overlay'
		data-ingredients-overlay
		aria-hidden='true'
	>
		<section
			class='ingredients-modal__panel'
			role='dialog'
			aria-modal='true'
			aria-label={title}
			data-ingredients-dialog
		>
			<header class='ingredients-modal__header'>
				<h2 aria-label={title}>{title}</h2>
				<div class='ingredients-modal__actions'>
					<button
						type='button'
						class='ingredients-modal__reset'
						data-ingredients-reset
						aria-label='Reiniciar lista de compras'
					>
						Reiniciar
					</button>
					<PortionMultiplier
						id={`${modalBaseId}-multiplier`}
						wrapperClass='w-fit flex gap-2 items-center'
						labelClass='tabs-controls-label'
						selectClass='tabs-multiplier'
						ariaLabel='Multiplicar porciones de lista de compras'
						value={3}
					/>
					<button
						type='button'
						class='ingredients-modal__close'
						data-ingredients-close
						aria-label='Cerrar lista de compras'
					>
						Cerrar
					</button>
				</div>
			</header>
			<div class='ingredients-modal__content'>
				<TabsSlider tabs={weekTabs} ariaLabel='Semanas de lista de compras'>
					{
						resolvedWeeks.map((weekConfig) => (
							<section
								data-tab-panel={weekConfig.id}
								data-ingredients-storage-key={weekConfig.storageKey}
								class='p-1 md:p-2'
							>
								<div class='ingredients-modal__body'>
									{weekConfig.sectionColumns.map((columnKeys) => (
										<div class='ingredients-modal__column'>
											{columnKeys.map((key) => {
												const category = weekConfig.week[key];
												if (!isWeekCategory(category)) return null;
												return (
													<section
														class={`ingredients-modal__section ingredients-modal__section--${key}`}
													>
														<h3 class='font-bold text-xl'>
															{categoryNames[key] ?? key}
														</h3>
														{category.notas ? (
															<details class='ingredients-modal__notes'>
																<summary>Notas</summary>
																<p>{category.notas}</p>
															</details>
														) : null}
														<ul class='ingredients-modal__list'>
															{category.lista.map((item, index) => (
																<li
																	data-qty-base={item.cantidad}
																	data-qty-unit={item.unidad}
																	data-ingredient-id={getIngredientId(
																		weekConfig.id,
																		key,
																		item,
																		index,
																	)}
																>
																	<label class='ingredients-modal__item'>
																		<input
																			type='checkbox'
																			class='ingredients-modal__checkbox'
																			data-ingredient-checkbox
																		/>
																		<span class='ingredients-modal__item-text'>
																			<span class='ingredients-qty-value'>
																				{item.cantidad}
																			</span>
																			{item.unidad ? (
																				<span class='ingredients-qty-unit'>
																					{' '}
																					{displayUnit(item.unidad)}
																				</span>
																			) : null}{' '}
																			— {item.nombre}
																		</span>
																	</label>
																</li>
															))}
														</ul>
													</section>
												);
											})}
										</div>
									))}
								</div>
							</section>
						))
					}
				</TabsSlider>
			</div>
		</section>
	</div>
</div>

<script is:inline>
	(() => {
		const UNIT_DISPLAY = {
			piece: 'pieza',
			unit: 'unidad',
			unidad: 'unidad',
			pieza: 'pieza',
			g: 'g',
			gr: 'g',
			gramos: 'g',
			kg: 'kg',
			ml: 'ml',
			l: 'l',
			taza: 'taza',
			cup: 'taza',
			cda: 'cda',
			cucharada: 'cda',
			tbsp: 'cda',
			cdita: 'cdita',
			cucharadita: 'cdita',
			tsp: 'cdita',
			scoop: 'scoop',
			slice: 'rebanada',
			rebanada: 'rebanada',
		};
		const MULTIPLIER_EVENT = 'portions-multiplier:change';
		const parseMultiplier = (value) => {
			const parsed = Number(value);
			return Number.isFinite(parsed) && parsed > 0 ? parsed : 1;
		};
		const getCurrentMultiplier = () => {
			const select = document.querySelector('[data-portion-multiplier]');
			if (!(select instanceof HTMLSelectElement)) return 1;
			return parseMultiplier(select.value);
		};
		const readChecklistState = (storageKey) => {
			const raw = window.localStorage.getItem(storageKey);
			if (!raw) return {};
			try {
				const parsed = JSON.parse(raw);
				if (parsed && typeof parsed === 'object') return parsed;
			} catch (error) {
				console.warn('No se pudo leer la lista de compras guardada.', error);
			}
			return {};
		};
		const saveChecklistState = (storageKey, state) => {
			try {
				window.localStorage.setItem(storageKey, JSON.stringify(state));
			} catch (error) {
				console.warn('No se pudo guardar la lista de compras.', error);
			}
		};
		const getIngredientIdFromCheckbox = (checkbox) =>
			checkbox.closest('li')?.getAttribute('data-ingredient-id') ?? '';
		const setCheckedClass = (checkbox, isChecked) => {
			const itemNode = checkbox.closest('li');
			if (itemNode) itemNode.classList.toggle('is-checked', isChecked);
		};

		const FRACTIONS = [
			[1 / 8, '⅛'],
			[1 / 4, '¼'],
			[1 / 3, '⅓'],
			[1 / 2, '½'],
			[2 / 3, '⅔'],
			[3 / 4, '¾'],
		];
		const FRACTION_UNITS = new Set([
			'taza',
			'cda',
			'cdita',
			'cup',
			'tbsp',
			'tsp',
		]);
		const formatQuantityClient = (value, unit) => {
			const useFraction =
				typeof unit === 'string' && FRACTION_UNITS.has(unit.toLowerCase());
			if (!useFraction) {
				if (Number.isInteger(value)) return String(value);
				const rounded = Math.round(value * 100) / 100;
				return String(rounded).replace(/\.0+$/, '');
			}

			const whole = Math.floor(value);
			const decimal = value - whole;
			if (decimal < 0.01) return whole === 0 ? '0' : String(whole);

			let best = FRACTIONS[0];
			for (const fraction of FRACTIONS) {
				if (Math.abs(fraction[0] - decimal) < Math.abs(best[0] - decimal)) {
					best = fraction;
				}
			}
			const [closestFraction, symbol] = best;
			if (Math.abs(closestFraction - decimal) > 0.04) return String(value);
			return whole === 0 ? symbol : `${whole}${symbol}`;
		};

		const roots = document.querySelectorAll('[data-ingredients-modal]');
		for (const root of roots) {
			const trigger = root.querySelector('[data-ingredients-trigger]');
			const overlay = root.querySelector('[data-ingredients-overlay]');
			const dialog = root.querySelector('[data-ingredients-dialog]');
			const closeButton = root.querySelector('[data-ingredients-close]');
			const resetButton = root.querySelector('[data-ingredients-reset]');

			if (
				!(trigger instanceof HTMLButtonElement) ||
				!(overlay instanceof HTMLElement) ||
				!(dialog instanceof HTMLElement) ||
				!(closeButton instanceof HTMLButtonElement) ||
				!(resetButton instanceof HTMLButtonElement)
			) {
				continue;
			}

			// Move overlay to document.body to avoid stacking/transform containment
			if (overlay.parentElement !== document.body) {
				document.body.appendChild(overlay);
			}

			const weekButtons = Array.from(
				overlay.querySelectorAll('[data-tab-target]'),
			).filter((node) => node instanceof HTMLButtonElement);
			const weekPanels = Array.from(
				overlay.querySelectorAll('[data-tab-panel]'),
			).filter((node) => node instanceof HTMLElement);
			const checklistStateByStorageKey = new Map();

			const getPanelStorageKey = (panel) =>
				panel.getAttribute('data-ingredients-storage-key') ??
				'ingredients-checklist-default';

			const ensureChecklistState = (storageKey) => {
				if (!checklistStateByStorageKey.has(storageKey)) {
					checklistStateByStorageKey.set(
						storageKey,
						readChecklistState(storageKey),
					);
				}
				return checklistStateByStorageKey.get(storageKey) ?? {};
			};

			const applyChecklistStateToPanel = (panel) => {
				const storageKey = getPanelStorageKey(panel);
				const state = ensureChecklistState(storageKey);
				const ingredientCheckboxes = Array.from(
					panel.querySelectorAll('[data-ingredient-checkbox]'),
				).filter((node) => node instanceof HTMLInputElement);

				ingredientCheckboxes.forEach((checkbox) => {
					const ingredientId = getIngredientIdFromCheckbox(checkbox);
					const isChecked = Boolean(ingredientId && state[ingredientId]);
					checkbox.checked = isChecked;
					setCheckedClass(checkbox, isChecked);
				});
			};

			const updateModalQuantities = (multiplier) => {
				const qtyNodes = Array.from(
					overlay.querySelectorAll('[data-qty-base]'),
				);
				qtyNodes.forEach((node) => {
					const base = Number(node.getAttribute('data-qty-base'));
					if (Number.isNaN(base)) return;
					const rawUnit = node.getAttribute('data-qty-unit') ?? '';
					const displayedUnit = UNIT_DISPLAY[rawUnit.toLowerCase()] ?? rawUnit;
					const newValue = base * multiplier;
					const formatted = formatQuantityClient(newValue, rawUnit);
					const valueEl = node.querySelector('.ingredients-qty-value');
					const unitEl = node.querySelector('.ingredients-qty-unit');
					if (valueEl) valueEl.textContent = formatted;
					if (unitEl)
						unitEl.textContent = displayedUnit ? ' ' + displayedUnit : '';
				});
			};

			let isOpen = false;
			let lastFocusedElement = null;
			let activeWeekId =
				root.getAttribute('data-ingredients-default-week') ?? '';

			const getActivePanel = () =>
				weekPanels.find(
					(panel) => panel.getAttribute('data-tab-panel') === activeWeekId,
				) ??
				weekPanels[0] ??
				null;

			const setActiveWeek = (nextWeekId) => {
				if (!nextWeekId) return;
				activeWeekId = nextWeekId;
				const activePanel = getActivePanel();
				if (activePanel) applyChecklistStateToPanel(activePanel);
				updateModalQuantities(getCurrentMultiplier());
			};

			trigger.setAttribute('aria-expanded', 'false');
			weekPanels.forEach((panel) => applyChecklistStateToPanel(panel));
			const initialWeekId =
				activeWeekId || weekPanels[0]?.getAttribute('data-tab-panel') || '';
			if (initialWeekId) {
				setActiveWeek(initialWeekId, false);
			}

			const openModal = () => {
				if (isOpen) return;
				isOpen = true;
				lastFocusedElement = document.activeElement;
				overlay.classList.add('is-open');
				overlay.setAttribute('aria-hidden', 'false');
				trigger.setAttribute('aria-expanded', 'true');
				document.body.classList.add('has-ingredients-modal');
				updateModalQuantities(getCurrentMultiplier());
				requestAnimationFrame(() => closeButton.focus());
			};

			const closeModal = () => {
				if (!isOpen) return;
				isOpen = false;
				overlay.classList.remove('is-open');
				overlay.setAttribute('aria-hidden', 'true');
				trigger.setAttribute('aria-expanded', 'false');
				document.body.classList.remove('has-ingredients-modal');
				if (lastFocusedElement instanceof HTMLElement) {
					lastFocusedElement.focus();
				}
			};

			overlay.addEventListener('change', (event) => {
				const checkbox = event.target;
				if (
					!(checkbox instanceof HTMLInputElement) ||
					!checkbox.matches('[data-ingredient-checkbox]')
				) {
					return;
				}

				const ingredientId = getIngredientIdFromCheckbox(checkbox);
				if (!ingredientId) return;
				const panel = checkbox.closest('[data-tab-panel]');
				if (!(panel instanceof HTMLElement)) return;

				const storageKey = getPanelStorageKey(panel);
				const state = ensureChecklistState(storageKey);
				if (checkbox.checked) state[ingredientId] = true;
				else delete state[ingredientId];
				setCheckedClass(checkbox, checkbox.checked);
				saveChecklistState(storageKey, state);
			});

			weekButtons.forEach((button, index) => {
				button.addEventListener('click', () => {
					const targetWeek = button.getAttribute('data-tab-target');
					if (!targetWeek) return;
					setActiveWeek(targetWeek);
				});

				button.addEventListener('keydown', (event) => {
					if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') {
						return;
					}
					const direction = event.key === 'ArrowRight' ? 1 : -1;
					const nextIndex =
						(index + direction + weekButtons.length) % weekButtons.length;
					const nextButton = weekButtons[nextIndex];
					const targetWeek = nextButton?.getAttribute('data-tab-target') ?? '';
					setActiveWeek(targetWeek);
				});
			});

			trigger.addEventListener('click', openModal);
			closeButton.addEventListener('click', closeModal);
			resetButton.addEventListener('click', () => {
				const activePanel = getActivePanel();
				if (!(activePanel instanceof HTMLElement)) return;

				const confirmed = window.confirm(
					'¿Quieres reiniciar la lista de esta SEMANA?',
				);
				if (!confirmed) return;

				const storageKey = getPanelStorageKey(activePanel);
				checklistStateByStorageKey.set(storageKey, {});
				saveChecklistState(storageKey, {});
				applyChecklistStateToPanel(activePanel);
			});
			overlay.addEventListener('click', (event) => {
				if (event.target === overlay) closeModal();
			});
			window.addEventListener('keydown', (event) => {
				if (event.key === 'Escape' && isOpen) closeModal();
			});

			window.addEventListener(MULTIPLIER_EVENT, (event) => {
				const detail = event instanceof CustomEvent ? event.detail : null;
				updateModalQuantities(parseMultiplier(detail?.multiplier));
			});
			updateModalQuantities(getCurrentMultiplier());
		}
	})();
</script>

<style>
	.ingredients-modal {
		position: relative;
		display: inline-flex;
		align-items: center;
	}
	.ingredients-modal__trigger {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		border-radius: 9999px;
		border: 1px solid #b8b8b9;
		background: rgba(255, 255, 255, 0.92);
		color: #334155;
		font-size: 0.875rem;
		font-weight: 700;
		line-height: 1;
		padding: 0.6rem 0.95rem;
		cursor: pointer;
	}
	.ingredients-modal__overlay {
		position: fixed;
		inset: 0;
		z-index: 60;
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding: 1.25rem 1rem;
		overflow-y: auto;
		background: rgba(15, 23, 42, 0.28);
		backdrop-filter: blur(2px);
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition:
			opacity 220ms ease,
			visibility 220ms ease;
	}
	.ingredients-modal__panel {
		width: min(72rem, 92vw);
		max-height: none;
		border-radius: 1rem;
		border: 1px solid #e2e8f0;
		background: #ffffff;
		box-shadow:
			0 26px 60px -35px rgba(15, 23, 42, 0.7),
			0 12px 28px -18px rgba(15, 23, 42, 0.45);
		transform: translateY(14px) scale(0.98);
		transition: transform 240ms cubic-bezier(0.22, 1, 0.36, 1);
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}
	.ingredients-modal__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		flex-wrap: wrap;
		padding: 0.9rem 1.15rem;
		border-bottom: 1px solid #e2e8f0;
		background: #f8fafc;
	}
	.ingredients-modal__header h2 {
		margin: 0;
		font-size: 1rem;
		font-weight: 800;
		color: #0f172a;
	}
	.ingredients-modal__actions {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		flex-wrap: wrap;
		margin-left: auto;
		justify-content: flex-end;
	}
	.ingredients-modal__reset {
		border-radius: 0.65rem;
		border: 1px solid #f59e0b;
		background: linear-gradient(180deg, #fff7ed 0%, #ffedd5 100%);
		color: #7c2d12;
		font-size: 0.8rem;
		font-weight: 700;
		padding: 0.44rem 0.72rem;
		cursor: pointer;
		transition:
			background-color 140ms ease,
			border-color 140ms ease,
			box-shadow 140ms ease,
			transform 140ms ease;
		box-shadow: 0 1px 2px rgba(124, 45, 18, 0.14);
	}
	.ingredients-modal__reset:hover {
		background: linear-gradient(180deg, #ffedd5 0%, #fed7aa 100%);
		border-color: #ea580c;
	}
	.ingredients-modal__reset:active {
		transform: translateY(1px);
	}
	.ingredients-modal__reset:focus-visible {
		outline: 2px solid #fb923c;
		outline-offset: 1px;
	}
	.ingredients-modal__close {
		border-radius: 0.6rem;
		border: 1px solid #cbd5e1;
		background: #ffffff;
		color: #334155;
		font-size: 0.8rem;
		font-weight: 700;
		padding: 0.4rem 0.65rem;
		cursor: pointer;
	}
	.ingredients-modal__content {
		padding: 1rem 1.15rem 1.2rem;
		flex: 1 1 auto;
		min-height: 0;
		overflow: visible;
	}
	/* Override TabsSlider to render as a centered static pill row inside the modal */
	.ingredients-modal__content :global(.tabs-list) {
		position: relative !important;
		top: auto !important;
