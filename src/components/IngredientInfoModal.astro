---
import ingredientsData from '../data/ingredients.json';

interface Props {
	title?: string;
	triggerLabel?: string;
}

type Difficulty = 'comun' | 'medio' | 'dificil';

interface IngredientEntry {
	nombre: string;
	enlace: string;
}

type IngredientsByDifficulty = Record<Difficulty, IngredientEntry[]>;

const { title = 'Ingredientes', triggerLabel = 'Ingredientes' } = Astro.props;

const ingredientsByDifficulty = ingredientsData as IngredientsByDifficulty;
const difficultyOrder: Difficulty[] = ['comun', 'medio', 'dificil'];
const difficultyLabels: Record<Difficulty, string> = {
	comun: 'Común',
	medio: 'Medio',
	dificil: 'Difícil',
};
---

<div class='readme-modal' data-readme-modal>
	<button
		type='button'
		class='readme-modal__trigger'
		data-readme-trigger
		aria-haspopup='dialog'
	>
		{triggerLabel}
	</button>

	<div class='readme-modal__overlay' data-readme-overlay aria-hidden='true'>
		<section
			class='readme-modal__panel'
			role='dialog'
			aria-modal='true'
			aria-label={title}
			data-readme-dialog
		>
			<header class='readme-modal__header'>
				<h2 aria-label={title}>{title}</h2>
				<button
					type='button'
					class='readme-modal__close'
					data-readme-close
					aria-label='Cerrar ayuda'
				>
					Cerrar
				</button>
			</header>
			<div class='readme-modal__content'>
				<div class='readme-modal__ingredients'>
					{
						difficultyOrder.map((difficulty) => (
							<section class='readme-modal__group'>
								<h3>{difficultyLabels[difficulty]}</h3>
								<ul class='readme-modal__grid'>
									{ingredientsByDifficulty[difficulty].map((ingredient) => (
										<li>
											<a
												href={ingredient.enlace}
												target='_blank'
												rel='noopener noreferrer'
											>
												{ingredient.nombre}
											</a>
										</li>
									))}
								</ul>
							</section>
						))
					}
				</div>
			</div>
		</section>
	</div>
</div>

<script is:inline>
	const modalRoots = document.querySelectorAll('[data-readme-modal]');

	for (const root of modalRoots) {
		const trigger = root.querySelector('[data-readme-trigger]');
		const overlay = root.querySelector('[data-readme-overlay]');
		const dialog = root.querySelector('[data-readme-dialog]');
		const closeButton = root.querySelector('[data-readme-close]');

		if (
			!(trigger instanceof HTMLButtonElement) ||
			!(overlay instanceof HTMLElement) ||
			!(dialog instanceof HTMLElement) ||
			!(closeButton instanceof HTMLButtonElement)
		) {
			continue;
		}

		if (overlay.parentElement !== document.body) {
			document.body.appendChild(overlay);
		}

		trigger.setAttribute('aria-expanded', 'false');

		let isOpen = false;
		let lastFocusedElement = null;

		const closeModal = () => {
			if (!isOpen) {
				return;
			}

			isOpen = false;
			overlay.classList.remove('is-open');
			overlay.setAttribute('aria-hidden', 'true');
			trigger.setAttribute('aria-expanded', 'false');
			document.body.classList.remove('has-readme-modal');

			if (lastFocusedElement instanceof HTMLElement) {
				lastFocusedElement.focus();
			}
		};

		const openModal = () => {
			if (isOpen) {
				return;
			}

			isOpen = true;
			lastFocusedElement = document.activeElement;
			overlay.classList.add('is-open');
			overlay.setAttribute('aria-hidden', 'false');
			trigger.setAttribute('aria-expanded', 'true');
			document.body.classList.add('has-readme-modal');
			requestAnimationFrame(() => {
				closeButton.focus();
			});
		};

		trigger.addEventListener('click', openModal);
		closeButton.addEventListener('click', closeModal);

		overlay.addEventListener('click', (event) => {
			if (event.target === overlay) {
				closeModal();
			}
		});

		window.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && isOpen) {
				closeModal();
			}
		});
	}
</script>

<style>
	.readme-modal {
		position: relative;
		display: inline-flex;
		align-items: center;
	}

	.readme-modal__trigger {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.35rem;
		border-radius: 9999px;
		border: 1px solid #b8b8b9;
		background: rgba(255, 255, 255, 0.92);
		color: #334155;
		font-size: 0.875rem;
		font-weight: 700;
		line-height: 1;
		padding: 0.6rem 0.95rem;
		cursor: pointer;
		transition:
			background-color 180ms ease,
			transform 180ms ease,
			box-shadow 180ms ease;
	}

	.readme-modal__trigger:hover {
		background: #f8fafc;
		box-shadow: 0 10px 18px -14px rgba(15, 23, 42, 0.65);
		transform: translateY(-1px);
	}

	.readme-modal__overlay {
		position: fixed;
		inset: 0;
		z-index: 60;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem;
		background: rgba(15, 23, 42, 0.28);
		backdrop-filter: var(--shared-backdrop-filter);
		-webkit-backdrop-filter: var(--shared-backdrop-filter);
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition:
			opacity 220ms ease,
			visibility 220ms ease;
	}

	.readme-modal__panel {
		width: min(72rem, 94vw);
		max-height: min(86vh, 52rem);
		border-radius: 1rem;
		border: 1px solid #e2e8f0;
		background: #ffffff;
		box-shadow:
			0 26px 60px -35px rgba(15, 23, 42, 0.7),
			0 12px 28px -18px rgba(15, 23, 42, 0.45);
		transform: translateY(14px) scale(0.98);
		transition: transform 240ms cubic-bezier(0.22, 1, 0.36, 1);
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}

	.readme-modal__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		padding: 0.9rem 1.15rem;
		border-bottom: 1px solid #e2e8f0;
		background: #f8fafc;
	}

	.readme-modal__header h2 {
		margin: 0;
		font-size: 1rem;
		font-weight: 800;
		color: #0f172a;
	}

	.readme-modal__close {
		border-radius: 0.6rem;
		border: 1px solid #cbd5e1;
		background: #ffffff;
		color: #334155;
		font-size: 0.8rem;
		font-weight: 700;
		padding: 0.4rem 0.65rem;
		cursor: pointer;
	}

	.readme-modal__content {
		padding: 1rem 1.15rem 1.2rem;
		overflow: auto;
	}

	.readme-modal__ingredients {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.readme-modal__group {
		border: 1px solid #e2e8f0;
		border-radius: 0.85rem;
		padding: 0.9rem;
		background: #f8fafc;
	}

	.readme-modal__group h3 {
		margin: 0 0 0.65rem;
		font-size: 0.95rem;
		font-weight: 800;
		color: #0f172a;
	}

	.readme-modal__grid {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.45rem 1rem;
	}

	.readme-modal__grid li {
		min-width: 0;
	}

	.readme-modal__grid a {
		display: inline-block;
		font-size: 0.86rem;
		line-height: 1.35;
		color: #1e293b;
		text-decoration: none;
		word-break: break-word;
	}

	.readme-modal__grid a:hover {
		color: #0369a1;
		text-decoration: underline;
		text-underline-offset: 2px;
	}

	@media (min-width: 900px) {
		.readme-modal__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (min-width: 1280px) {
		.readme-modal__grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
	}

	.readme-modal__overlay.is-open {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
	}

	.readme-modal__overlay.is-open .readme-modal__panel {
		transform: translateY(0) scale(1);
	}

	:global(body.has-readme-modal) {
		overflow: hidden;
	}

	@media (max-width: 640px) {
		.readme-modal__overlay {
			padding: 0;
			align-items: flex-end;
		}

		.readme-modal__panel {
			width: 100%;
			max-height: 100dvh;
			border-radius: 1rem 1rem 0 0;
			border-left: none;
			border-right: none;
			border-bottom: none;
		}
	}
</style>
