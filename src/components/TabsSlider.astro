---
interface TabItem {
	id: string;
	label: string;
}

interface Props {
	tabs: TabItem[];
}

const { tabs } = Astro.props;
const defaultTabId = tabs[0]?.id ?? "";
---

<div class='tabs-slider ' data-tabs-slider data-tabs-default={defaultTabId}>
	<div class='tabs-list' data-tabs-list role='tablist' aria-label='Secciones del plan alimenticio'>
		{
			tabs.map((tab, index) => (
				<button
					type='button'
					role='tab'
					class={`tabs-trigger ${index === 0 ? "is-active" : ""}`}
					data-tab-target={tab.id}
					aria-selected={index === 0 ? "true" : "false"}
					tabindex={index === 0 ? "0" : "-1"}
				>
					{tab.label}
				</button>
			))
		}
	</div>
	<div class='tabs-viewport' data-tabs-viewport>
		<div class='tabs-track' data-tabs-track>
			<slot />
		</div>
	</div>
</div>

<script is:inline>
	const roots = document.querySelectorAll("[data-tabs-slider]");

	for (const root of roots) {
		const viewport = root.querySelector("[data-tabs-viewport]");
		const track = root.querySelector("[data-tabs-track]");
		const tabsList = root.querySelector("[data-tabs-list]");
		const buttons = Array.from(root.querySelectorAll("[data-tab-target]"));
		const stickyHeader = document.querySelector("[data-tabs-sticky-header]");

		if (
			!(viewport instanceof HTMLElement) ||
			!(track instanceof HTMLElement) ||
			!(tabsList instanceof HTMLElement) ||
			buttons.length === 0
		) {
			continue;
		}

		const panels = Array.from(track.children).filter(
			(node) => node instanceof HTMLElement && node.hasAttribute("data-tab-panel"),
		);

		if (panels.length === 0) {
			continue;
		}

		const panelIds = panels.map((panel) => panel.getAttribute("data-tab-panel") ?? "");
		const defaultTabId = root.getAttribute("data-tabs-default") ?? "";
		const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		let activeIndex = Math.max(0, panelIds.indexOf(defaultTabId));

		const setTabsOffsets = () => {
			if (stickyHeader instanceof HTMLElement) {
				root.style.setProperty("--tabs-sticky-top", `${stickyHeader.getBoundingClientRect().height}px`);
			} else {
				root.style.setProperty("--tabs-sticky-top", "0px");
			}

			root.style.setProperty("--tabs-list-height", `${tabsList.getBoundingClientRect().height}px`);
		};

		const setActiveTab = (nextIndex, smooth) => {
			if (nextIndex < 0 || nextIndex >= panels.length) {
				return;
			}

			activeIndex = nextIndex;
			const offset = viewport.clientWidth * activeIndex;
			track.style.transition = smooth
				? "transform 420ms cubic-bezier(0.22, 1, 0.36, 1)"
				: "none";
			track.style.transform = `translate3d(-${offset}px, 0, 0)`;

			buttons.forEach((button, index) => {
				const isActive = index === activeIndex;
				button.setAttribute("aria-selected", String(isActive));
				button.setAttribute("tabindex", isActive ? "0" : "-1");
				button.classList.toggle("is-active", isActive);
			});

			panels.forEach((panel, index) => {
				const isActive = index === activeIndex;
				panel.setAttribute("aria-hidden", String(!isActive));
			});
		};

		buttons.forEach((button) => {
			button.addEventListener("click", () => {
				const target = button.getAttribute("data-tab-target") ?? "";
				const nextIndex = panelIds.indexOf(target);
				if (nextIndex !== -1) {
					setActiveTab(nextIndex, !prefersReducedMotion);
				}
			});

			button.addEventListener("keydown", (event) => {
				if (event.key !== "ArrowRight" && event.key !== "ArrowLeft") {
					return;
				}

				event.preventDefault();
				const direction = event.key === "ArrowRight" ? 1 : -1;
				const nextIndex = (activeIndex + direction + buttons.length) % buttons.length;
				setActiveTab(nextIndex, !prefersReducedMotion);
				buttons[nextIndex].focus();
			});
		});

		window.addEventListener(
			"resize",
			() => {
				setTabsOffsets();
				setActiveTab(activeIndex, false);
			},
			{ passive: true },
		);

		if (stickyHeader instanceof HTMLElement && "ResizeObserver" in window) {
			const headerObserver = new ResizeObserver(() => {
				setTabsOffsets();
			});
			headerObserver.observe(stickyHeader);
		}

		if ("ResizeObserver" in window) {
			const rootObserver = new ResizeObserver(() => {
				setTabsOffsets();
				setActiveTab(activeIndex, false);
			});
			rootObserver.observe(root);
		}

		setTabsOffsets();
		setActiveTab(activeIndex, false);
	}
</script>

<style>
	.tabs-slider {
		width: 100%;
		--tabs-sticky-top: 0px;
		--tabs-list-height: 0px;
	}

	.tabs-list {
		position: fixed;
		left: 0;
		width: 100%;
		transform: none;
		top: var(--tabs-sticky-top, 0px);
		z-index: 9;
		display: flex;
		gap: 0.5rem;
		overflow-x: auto;
		padding: 0.75rem 0.5rem;
		background: rgba(255, 255, 255, 0.92);
		backdrop-filter: blur(6px);
		border: 2px solid #b8b8b9;
		border-top: none;
		border-radius: 0 0 1.5rem 1.5rem;
		scrollbar-width: thin;
	}

	.tabs-trigger {
		flex: 1 1 0;
		min-width: max-content;
		padding: 0.625rem 1rem;
		border-radius: 9999px;
		border: 1px solid #b8b8b9;
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.1;
		color: #374151;
		background: #f9fafb;
		cursor: pointer;
		transition:
			background-color 180ms ease,
			color 180ms ease,
			border-color 180ms ease;
	}

	.tabs-trigger:hover {
		background: #f3f4f6;
	}

	.tabs-trigger.is-active {
		border-color: #0f766e;
		background: #0f766e;
		color: #ffffff;
	}

	.tabs-viewport {
		overflow: hidden;
		width: 100%;
		padding-top: var(--tabs-list-height);
	}

	.tabs-track {
		display: flex;
		width: 100%;
		will-change: transform;
	}

	.tabs-track :global([data-tab-panel]) {
		flex: 0 0 100%;
		width: 100%;
	}

	@media (min-width: 1024px) {
		.tabs-list {
			left: 50%;
			transform: translateX(-50%);
			width: clamp(22rem, 34vw, 36rem);
		}
	}

	@media (max-width: 500px) {
		.tabs-trigger {
			flex: 0 0 auto;
		}
	}

	@media print {
		.tabs-list {
			display: none !important;
		}

		.tabs-viewport {
			overflow: visible !important;
			padding-top: 0 !important;
		}

		.tabs-track {
			display: block !important;
			transform: none !important;
		}

		.tabs-track :global([data-tab-panel]) {
			width: 100% !important;
		}
	}
</style>
