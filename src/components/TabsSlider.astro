---
interface TabItem {
	id: string;
	label: string;
}

interface Props {
	tabs: TabItem[];
	ariaLabel?: string;
}

const { tabs, ariaLabel = 'Secciones del plan alimenticio' } = Astro.props;
const defaultTabId = tabs[0]?.id ?? '';
---

<div class='tabs-slider' data-tabs-slider data-tabs-default={defaultTabId}>
	<div class='tabs-list' data-tabs-list role='tablist' aria-label={ariaLabel}>
		{
			tabs.map((tab, index) => (
				<button
					type='button'
					role='tab'
					class={`tabs-trigger ${index === 0 ? 'is-active' : ''}`}
					data-tab-target={tab.id}
					aria-selected={index === 0 ? 'true' : 'false'}
					tabindex={index === 0 ? '0' : '-1'}
				>
					{tab.label}
				</button>
			))
		}
		<div class='tabs-controls' data-tabs-controls>
			<slot name='tabs-controls-extra' />
		</div>
	</div>
	<div class='tabs-viewport' data-tabs-viewport>
		<div class='tabs-track' data-tabs-track>
			<slot />
		</div>
	</div>
</div>

<script is:inline>
	(() => {
		const ROOT_SELECTOR = '[data-tabs-slider]';
		const INIT_ATTR = 'data-tabs-initialized';

		const initRoot = (root) => {
			if (!(root instanceof HTMLElement) || root.hasAttribute(INIT_ATTR)) {
				return;
			}

			const directChildren = Array.from(root.children);
			const tabsList = directChildren.find(
				(node) =>
					node instanceof HTMLElement && node.hasAttribute('data-tabs-list'),
			);
			const viewport = directChildren.find(
				(node) =>
					node instanceof HTMLElement &&
					node.hasAttribute('data-tabs-viewport'),
			);
			const track =
				viewport instanceof HTMLElement
					? Array.from(viewport.children).find(
							(node) =>
								node instanceof HTMLElement &&
								node.hasAttribute('data-tabs-track'),
						)
					: null;

			if (
				!(viewport instanceof HTMLElement) ||
				!(track instanceof HTMLElement) ||
				!(tabsList instanceof HTMLElement)
			) {
				return;
			}

			const buttons = Array.from(tabsList.children).filter(
				(node) =>
					node instanceof HTMLButtonElement &&
					node.hasAttribute('data-tab-target'),
			);

			if (buttons.length === 0) {
				return;
			}

			const panels = Array.from(track.children).filter(
				(node) =>
					node instanceof HTMLElement && node.hasAttribute('data-tab-panel'),
			);

			if (panels.length === 0) {
				return;
			}

			root.setAttribute(INIT_ATTR, 'true');

			const panelIds = panels.map(
				(panel) => panel.getAttribute('data-tab-panel') ?? '',
			);
			const defaultTabId = root.getAttribute('data-tabs-default') ?? '';
			const prefersReducedMotion = window.matchMedia(
				'(prefers-reduced-motion: reduce)',
			).matches;
			let activeIndex = Math.max(0, panelIds.indexOf(defaultTabId));

			const setTabsOffsets = () => {
				const stickyHeader = document.querySelector(
					'[data-tabs-sticky-header]',
				);
				if (stickyHeader instanceof HTMLElement) {
					root.style.setProperty(
						'--tabs-sticky-top',
						`${stickyHeader.getBoundingClientRect().height}px`,
					);
				} else {
					root.style.setProperty('--tabs-sticky-top', '0px');
				}

				root.style.setProperty(
					'--tabs-list-height',
					`${tabsList.getBoundingClientRect().height}px`,
				);
			};

			const setActiveTab = (nextIndex, smooth) => {
				if (nextIndex < 0 || nextIndex >= panels.length) {
					return;
				}

				activeIndex = nextIndex;
				const offset = viewport.clientWidth * activeIndex;
				track.style.transition = smooth
					? 'transform 420ms cubic-bezier(0.22, 1, 0.36, 1)'
					: 'none';
				track.style.transform = `translate3d(-${offset}px, 0, 0)`;

				buttons.forEach((button, index) => {
					const isActive = index === activeIndex;
					button.setAttribute('aria-selected', String(isActive));
					button.setAttribute('tabindex', isActive ? '0' : '-1');
					button.classList.toggle('is-active', isActive);
				});

				panels.forEach((panel, index) => {
					const isActive = index === activeIndex;
					panel.setAttribute('aria-hidden', String(!isActive));
				});
			};

			buttons.forEach((button) => {
				button.addEventListener('click', () => {
					const target = button.getAttribute('data-tab-target') ?? '';
					const nextIndex = panelIds.indexOf(target);
					if (nextIndex !== -1) {
						setActiveTab(nextIndex, !prefersReducedMotion);
					}
				});

				button.addEventListener('keydown', (event) => {
					if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') {
						return;
					}

					event.preventDefault();
					const direction = event.key === 'ArrowRight' ? 1 : -1;
					const nextIndex =
						(activeIndex + direction + buttons.length) % buttons.length;
					setActiveTab(nextIndex, !prefersReducedMotion);
					buttons[nextIndex].focus();
				});
			});

			window.addEventListener(
				'resize',
				() => {
					setTabsOffsets();
					setActiveTab(activeIndex, false);
				},
				{ passive: true },
			);

			const stickyHeader = document.querySelector('[data-tabs-sticky-header]');
			if (stickyHeader instanceof HTMLElement && 'ResizeObserver' in window) {
				const headerObserver = new ResizeObserver(() => {
					setTabsOffsets();
				});
				headerObserver.observe(stickyHeader);
			}

			if ('ResizeObserver' in window) {
				const rootObserver = new ResizeObserver(() => {
					setTabsOffsets();
					setActiveTab(activeIndex, false);
				});
				rootObserver.observe(root);
			}

			window.addEventListener(
				'load',
				() => {
					setTabsOffsets();
					setActiveTab(activeIndex, false);
				},
				{ once: true },
			);

			setTabsOffsets();
			setActiveTab(activeIndex, false);

			// Multiplier logic: update ingredient quantities shown in panels
			const MULTIPLIER_EVENT = 'portions-multiplier:change';
			const parseMultiplier = (value) => {
				const parsed = Number(value);
				return Number.isFinite(parsed) && parsed > 0 ? parsed : 1;
			};
			const getCurrentMultiplier = () => {
				const select = document.querySelector('[data-portion-multiplier]');
				if (!(select instanceof HTMLSelectElement)) return 1;
				return parseMultiplier(select.value);
			};

			const FRACTIONS = [
				[1 / 8, '⅛'],
				[1 / 4, '¼'],
				[1 / 3, '⅓'],
				[1 / 2, '½'],
				[2 / 3, '⅔'],
				[3 / 4, '¾'],
			];

			const FRACTION_UNITS = new Set([
				'taza',
				'cda',
				'cdita',
				'cup',
				'tbsp',
				'tsp',
			]);

			const formatQuantityClient = (value, unit) => {
				const useFraction =
					typeof unit === 'string' && FRACTION_UNITS.has(unit.toLowerCase());
				if (!useFraction) {
					if (Number.isInteger(value)) return String(value);
					const rounded = Math.round(value * 100) / 100;
					return String(rounded).replace(/\.0+$/, '');
				}

				const whole = Math.floor(value);
				const decimal = value - whole;
				if (decimal < 0.01) return whole === 0 ? '0' : String(whole);

				let best = FRACTIONS[0];
				for (const f of FRACTIONS) {
					if (Math.abs(f[0] - decimal) < Math.abs(best[0] - decimal)) best = f;
				}
				const [frac, symbol] = best;
				if (Math.abs(frac - decimal) > 0.04) return String(value);
				return whole === 0 ? symbol : `${whole}${symbol}`;
			};

			const parseLeadingQuantity = (text) => {
				if (!text) return null;
				const regex =
					/^\s*((?:\d+\s+\d+\/\d+)|\d+\/\d+|\d+(?:\.\d+)?|[½¼¾⅛⅓⅔⅝⅜])/;
				const m = String(text).match(regex);
				if (!m) return null;
				const token = m[1];
				let num = 0;
				if (/^[½¼¾⅛⅓⅔⅝⅜]$/.test(token)) {
					const map = {
						'½': 0.5,
						'¼': 0.25,
						'¾': 0.75,
						'⅛': 0.125,
						'⅓': 1 / 3,
						'⅔': 2 / 3,
						'⅝': 0.625,
						'⅜': 0.375,
					};
					num = map[token] ?? 0;
				} else if (token.indexOf(' ') !== -1 && token.indexOf('/') !== -1) {
					const parts = token.split(/\s+/);
					const whole = Number(parts[0]);
					const [n, d] = parts[1].split('/');
					num = whole + Number(n) / Number(d);
				} else if (token.indexOf('/') !== -1) {
					const [n, d] = token.split('/');
					num = Number(n) / Number(d);
				} else {
					num = Number(token);
				}
				const rest = text.slice(m[0].length).trimStart();
				return { num, rest };
			};

			const updateQuantities = (mult) => {
				// structured ingredients (RecipeCard)
				const qtyNodes = Array.from(root.querySelectorAll('[data-qty-base]'));
				qtyNodes.forEach((node) => {
					const base = Number(node.getAttribute('data-qty-base'));
					if (Number.isNaN(base)) return;
					const unit = node.getAttribute('data-qty-unit') ?? '';
					const newValue = base * mult;
					const formatted = formatQuantityClient(newValue, unit);
					const valueEl = node.querySelector('.ingredient-qty-value');
					const unitEl = node.querySelector('.ingredient-qty-unit');
					if (valueEl) valueEl.textContent = formatted;
					if (unitEl) unitEl.textContent = unit ? ' ' + unit : '';
				});

				// smoothie / free-text ingredients (try to parse leading quantity)
				const rawItems = Array.from(
					root.querySelectorAll('[data-ingredient-raw]'),
				);
				rawItems.forEach((li) => {
					const raw = li.getAttribute('data-ingredient-raw') ?? '';
					const parsed = parseLeadingQuantity(raw);
					if (!parsed) return;
					const { num, rest } = parsed;
					const newValue = num * mult;
					const unitCandidate = rest.split(/\s+/)[0] ?? '';
					const formatted = formatQuantityClient(newValue, unitCandidate);
					const newText = `${formatted}${rest ? ' ' + rest : ''}`;
					const textEl = li.querySelector('.ingredient-text');
					if (textEl) textEl.textContent = newText;
					else li.textContent = newText;
				});

				// update headers
				const headers = Array.from(
					root.querySelectorAll('[data-ingredients-header]'),
				);
				headers.forEach((h) => {
					const n = Number(mult) || 1;
					h.textContent = `Ingredientes (${n === 1 ? '1 porción' : `${n} porciones`})`;
				});
			};

			window.addEventListener(MULTIPLIER_EVENT, (event) => {
				const detail = event instanceof CustomEvent ? event.detail : null;
				updateQuantities(parseMultiplier(detail?.multiplier));
			});
			updateQuantities(getCurrentMultiplier());
		};

		const initTabsSliders = () => {
			const roots = document.querySelectorAll(ROOT_SELECTOR);
			for (const root of roots) {
				initRoot(root);
			}
		};

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', initTabsSliders, {
				once: true,
			});
		} else {
			initTabsSliders();
		}

		requestAnimationFrame(() => {
			initTabsSliders();
		});
	})();
</script>

<style>
	.tabs-slider {
		width: 100%;
		--tabs-sticky-top: 0px;
		--tabs-list-height: 0px;
	}

	.tabs-list {
		position: fixed;
		left: 0;
		width: 100%;
		transform: none;
		top: var(--tabs-sticky-top, 0px);
		z-index: 9;
		display: flex;
		gap: 0.5rem;
		/* overflow-x: hidden; */
		padding: 0.75rem 0.5rem;
		background: rgba(255, 255, 255, 0.92);
		backdrop-filter: blur(6px);
		border: 2px solid #b8b8b9;
		border-top: none;
		border-radius: 0 0 1.5rem 1.5rem;
		scrollbar-width: thin;
	}

	.tabs-trigger {
		flex: 1 1 0;
		min-width: max-content;
		padding: 0.625rem 1rem;
		border-radius: 9999px;
		border: 1px solid #b8b8b9;
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1.1;
		color: #374151;
		background: #f9fafb;
		cursor: pointer;
		transition:
			background-color 180ms ease,
			color 180ms ease,
			border-color 180ms ease;
	}

	.tabs-trigger:hover {
		background: #f3f4f6;
	}

	.tabs-trigger.is-active {
		border-color: #439b44;
		background: #439b44;
		color: #ffffff;
	}

	.tabs-viewport {
		overflow: hidden;
		width: 100%;
		padding-top: var(--tabs-list-height);
	}

	.tabs-track {
		display: flex;
		width: 100%;
		will-change: transform;
	}

	.tabs-track :global([data-tab-panel]) {
		flex: 0 0 100%;
		width: 100%;
	}

	.tabs-controls {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		margin-left: 0.5rem;
		padding-left: 0.75rem;
		border-left: 1px solid #d1d5db;
	}

	:global(.tabs-controls-label) {
		font-weight: 700;
		font-size: 0.95rem;
		color: #374151;
		white-space: nowrap;
	}

	:global(.tabs-multiplier) {
		padding: 0.45rem 0.75rem;
		border-radius: 9999px;
		border: 1px solid #b8b8b9;
		background: #f9fafb;
		color: #374151;
		font-weight: 700;
		cursor: pointer;
		font-size: 0.95rem;
	}

	.tabs-controls :global(.tabs-controls-extra),
	.tabs-controls :global(.tabs-controls-actions) {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}

	@media (max-width: 1023px) {
		.tabs-list {
			flex-wrap: wrap;
		}
		.tabs-controls {
			order: 2;
			flex: 1 1 100%;
			width: 100%;
			justify-content: center;
			margin-top: 0.5rem;
			margin-left: 0;
			padding-left: 0;
			border-left: none;
		}
		:global(.tabs-controls-label) {
			display: inline-block;
			margin-right: 0.5rem;
		}
		.tabs-controls :global(.tabs-controls-extra),
		.tabs-controls :global(.tabs-controls-actions) {
			flex-wrap: wrap;
			justify-content: center;
		}
	}

	@media (min-width: 1024px) {
		.tabs-controls {
			margin-left: auto;
			order: 0;
			flex: 0 0 auto;
		}
	}

	@media (min-width: 1024px) {
		.tabs-list {
			left: 50%;
			transform: translateX(-50%);
			width: min(92vw, 78rem);
		}
	}

	@media (max-width: 640px) {
		:global([data-tabs-sticky-header]) {
			position: static !important;
			top: auto !important;
		}

		.tabs-list {
			justify-content: stretch;
			flex-wrap: wrap;
			/* overflow-x: visible; */
			overflow-x: hidden;
			padding: 0.625rem;
			border-width: 1px;
			border-top-width: 0;
			position: sticky;
			top: 0;
			left: 0;
			width: 100%;
		}

		.tabs-trigger {
			flex: 1 1 calc(50% - 0.25rem);
			min-width: calc(50% - 0.25rem);
			width: 100%;
			text-align: center;
			white-space: normal;
		}

		.tabs-viewport {
			padding-top: 0;
		}
	}

	@media print {
		.tabs-list {
			display: none !important;
		}

		.tabs-viewport {
			overflow: visible !important;
			padding-top: 0 !important;
		}

		.tabs-track {
			display: block !important;
			transform: none !important;
		}

		.tabs-track :global([data-tab-panel]) {
			width: 100% !important;
		}
	}
</style>
