---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Plan alimenticio' } = Astro.props;
---

<html lang='es'>
	<head>
		<meta charset='utf-8' />
		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
		<link rel='icon' type='image/png' sizes='192x192' href='/icons/icon-192.png' />
		<link rel='apple-touch-icon' href='/icons/apple-touch-icon.png' />
		<link rel='manifest' href='/manifest.webmanifest' />
		<meta name='theme-color' content='#2f6d4f' />
		<meta name='mobile-web-app-capable' content='yes' />
		<meta name='apple-mobile-web-app-capable' content='yes' />
		<meta name='apple-mobile-web-app-title' content='Plan alimenticio' />
		<meta name='apple-mobile-web-app-status-bar-style' content='default' />
		<meta name='color-scheme' content='light dark' />
		<meta name='viewport' content='width=device-width, initial-scale=1' />
		<meta name='generator' content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
		<script>
			(() => {
				const OPENED_FOR_PRINT_ATTR = 'data-opened-for-print';

				const openDetailsForPrint = () => {
					const detailNodes = document.querySelectorAll('details');
					for (const node of detailNodes) {
						if (!(node instanceof HTMLDetailsElement)) continue;
						if (!node.open) {
							node.open = true;
							node.setAttribute(OPENED_FOR_PRINT_ATTR, 'true');
						}
					}
				};

				const restoreDetailsAfterPrint = () => {
					const openedForPrintNodes = document.querySelectorAll(
						`details[${OPENED_FOR_PRINT_ATTR}="true"]`,
					);
					for (const node of openedForPrintNodes) {
						if (!(node instanceof HTMLDetailsElement)) continue;
						node.open = false;
						node.removeAttribute(OPENED_FOR_PRINT_ATTR);
					}
				};

				window.addEventListener('beforeprint', openDetailsForPrint);
				window.addEventListener('afterprint', restoreDetailsAfterPrint);

				if ('serviceWorker' in navigator && window.isSecureContext) {
					window.addEventListener('load', () => {
						navigator.serviceWorker.register('/sw.js').catch((error) => {
							console.warn('Service worker registration failed:', error);
						});
					});
				}
			})();
		</script>
	</body>
</html>
