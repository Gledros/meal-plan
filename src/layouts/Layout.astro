---
import '../styles/global.css';

interface Props {
	title?: string;
}

const {
	title = 'Plan alimenticio vegano semanal con recetas y guia completa',
} = Astro.props;
const description =
	'Descubre un plan alimenticio vegano semanal con smoothies, desayunos, comidas, cenas y extras, con lista de compras y guia de preparacion para cada semana.';
const siteUrl = 'https://meal-plan.dellarocca.mx';
const ogImageUrl = 'https://meal-plan.dellarocca.mx/images/og-image-1200x630.png';
---

<html lang='es'>
	<head>
		<meta charset='utf-8' />
		<meta name='viewport' content='width=device-width, initial-scale=1' />
		<title>{title}</title>
		<meta name='description' content={description} />
		<link rel='canonical' href={siteUrl} />
		<meta name='robots' content='index, follow' />

		<meta property='og:type' content='website' />
		<meta property='og:locale' content='es_MX' />
		<meta property='og:site_name' content='Plan alimenticio' />
		<meta property='og:title' content={title} />
		<meta property='og:description' content={description} />
		<meta property='og:url' content={siteUrl} />
		<meta property='og:image' content={ogImageUrl} />

		<meta name='twitter:card' content='summary_large_image' />
		<meta name='twitter:title' content={title} />
		<meta name='twitter:description' content={description} />
		<meta name='twitter:image' content={ogImageUrl} />

		<meta name='theme-color' content='#2f6d4f' />
		<meta name='color-scheme' content='light dark' />
		<meta name='apple-mobile-web-app-title' content='Plan alimenticio' />
		<meta
			name='referrer'
			content='strict-origin-when-cross-origin'
		/>

		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
		<link rel='icon' href='/favicon.ico' />
		<link rel='apple-touch-icon' href='/icons/apple-touch-icon.png' />
		<link rel='mask-icon' href='/safari-pinned-tab.svg' color='#2f6d4f' />
		<link rel='manifest' href='/manifest.webmanifest' />

		<script type='application/ld+json' set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'WebSite',
			name: 'Plan alimenticio',
			url: siteUrl,
			description,
			inLanguage: 'es-MX',
		})} />
	</head>
	<body>
		<slot />
		<script>
			(() => {
				const OPENED_FOR_PRINT_ATTR = 'data-opened-for-print';

				const openDetailsForPrint = () => {
					const detailNodes = document.querySelectorAll('details');
					for (const node of detailNodes) {
						if (!(node instanceof HTMLDetailsElement)) continue;
						if (!node.open) {
							node.open = true;
							node.setAttribute(OPENED_FOR_PRINT_ATTR, 'true');
						}
					}
				};

				const restoreDetailsAfterPrint = () => {
					const openedForPrintNodes = document.querySelectorAll(
						`details[${OPENED_FOR_PRINT_ATTR}="true"]`,
					);
					for (const node of openedForPrintNodes) {
						if (!(node instanceof HTMLDetailsElement)) continue;
						node.open = false;
						node.removeAttribute(OPENED_FOR_PRINT_ATTR);
					}
				};

				window.addEventListener('beforeprint', openDetailsForPrint);
				window.addEventListener('afterprint', restoreDetailsAfterPrint);

				if ('serviceWorker' in navigator && window.isSecureContext) {
					window.addEventListener('load', () => {
						navigator.serviceWorker.register('/sw.js').catch((error) => {
							console.warn('Service worker registration failed:', error);
						});
					});
				}
			})();
		</script>
	</body>
</html>
