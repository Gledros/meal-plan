---
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Plan alimenticio' } = Astro.props;
---

<html lang='es'>
	<head>
		<meta charset='utf-8' />
		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
		<link rel='icon' href='/images/favicon.svg' />
		<meta name='color-scheme' content='light dark' />
		<meta name='viewport' content='width=device-width' />
		<meta name='generator' content={Astro.generator} />
		<style is:inline>
			:root {
				--surface-translucent-bg: rgba(255, 255, 255, 0.82);
				--surface-translucent-border: rgba(184, 184, 185, 0.9);
				--surface-translucent-blur: 6px;
			}

			[data-tabs-sticky-header] {
				background: var(--surface-translucent-bg);
				border-color: var(--surface-translucent-border);
				backdrop-filter: blur(var(--surface-translucent-blur));
				-webkit-backdrop-filter: blur(var(--surface-translucent-blur));
			}

			@media (prefers-color-scheme: dark) {
				:root {
					--surface-translucent-bg: rgba(0, 0, 0, 0.72);
					--surface-translucent-border: rgba(163, 163, 163, 0.45);
				}

				[data-tabs-sticky-header] {
					border-bottom-color: rgba(163, 163, 163, 0.75);
				}
			}
		</style>
		<title>{title}</title>
	</head>
	<body>
		<slot />
		<script>
			(() => {
				const OPENED_FOR_PRINT_ATTR = 'data-opened-for-print';

				const openDetailsForPrint = () => {
					const detailNodes = document.querySelectorAll('details');
					for (const node of detailNodes) {
						if (!(node instanceof HTMLDetailsElement)) continue;
						if (!node.open) {
							node.open = true;
							node.setAttribute(OPENED_FOR_PRINT_ATTR, 'true');
						}
					}
				};

				const restoreDetailsAfterPrint = () => {
					const openedForPrintNodes = document.querySelectorAll(
						`details[${OPENED_FOR_PRINT_ATTR}="true"]`,
					);
					for (const node of openedForPrintNodes) {
						if (!(node instanceof HTMLDetailsElement)) continue;
						node.open = false;
						node.removeAttribute(OPENED_FOR_PRINT_ATTR);
					}
				};

				window.addEventListener('beforeprint', openDetailsForPrint);
				window.addEventListener('afterprint', restoreDetailsAfterPrint);
			})();
		</script>
	</body>
</html>
